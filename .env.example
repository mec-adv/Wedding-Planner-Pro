# Copie para .env na raiz e ajuste.
#
# PostgreSQL (servidor dev interno sys-dev / 10.1.1.92)
# Caracteres especiais na senha: codifique na URL (ex.: @ -> %40)
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@10.1.1.92:5432/casamento360

# Opcional: usado por scripts/create-database-sys-dev.cjs (senha em texto; não use @ na URL aqui)
# PGHOST=10.1.1.92
# PGUSER=postgres
# PGPASSWORD=

# API (Express)
PORT=8080

# Produção atrás de subcaminho (ex.: https://dominio/casamento360).
# Em desenvolvimento deixe vazio ou não defina — a API fica em /api e o Vite faz proxy.
# APP_BASE_PATH=/casamento360

# Opcional: pasta absoluta para imagens de presentes (upload). Se vazio, usa ../../uploads a partir do cwd do api-server.
# Em produção em /opt/app: UPLOAD_ROOT=/opt/app/uploads
# UPLOAD_ROOT=/opt/app/uploads

# Desenvolvimento: porta da API para o proxy do Vite (deve coincidir com PORT acima)
DEV_API_PORT=8080

# Frontend (Vite) em outro terminal ou via `pnpm dev` na raiz — use PORT=5173 e BASE_PATH=/
#
# Build de produção com subcaminho (exemplos; ajuste BASE_PATH e VITE_API_BASE juntos):
#   BASE_PATH=/casamento360/
#   PORT=5173
#   VITE_API_BASE=/casamento360/api

# Opcional em desenvolvimento (obrigatório em produção)
# JWT_SECRET=uma-chave-longa-e-aleatoria

# Origem permitida pelo CORS (obrigatório em produção; em dev o padrão já é http://localhost:5173)
# ALLOWED_ORIGIN=https://rgrservices.com.br
