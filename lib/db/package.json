{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "dotenv -e ../../.env -- drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "dotenv -e ../../.env -- drizzle-kit push --force --config ./drizzle.config.ts",
    "migrate-guest-groups": "dotenv -e ../../.env -- node ./scripts/migrate-guest-groups.cjs",
    "migrate-guest-companions": "dotenv -e ../../.env -- node ./scripts/migrate-guest-companions.cjs",
    "migrate-wedding-contact-venues": "dotenv -e ../../.env -- node ./scripts/migrate-wedding-contact-venues.cjs",
    "migrate-whatsapp-connections": "dotenv -e ../../.env -- node ./scripts/migrate-whatsapp-connections.cjs"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^7.4.4",
    "drizzle-kit": "^0.31.9"
  }
}
