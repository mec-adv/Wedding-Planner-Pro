# Copie para .env na raiz e ajuste.
#
# PostgreSQL (servidor dev interno sys-dev / 10.1.1.92)
# Caracteres especiais na senha: codifique na URL (ex.: @ -> %40)
DATABASE_URL=postgresql://postgres:P027gre2ql%4025@10.1.1.92:5432/casamento360

# Opcional: usado por scripts/create-database-sys-dev.cjs (senha em texto; não use @ na URL aqui)
# PGHOST=10.1.1.92
# PGUSER=postgres
# PGPASSWORD=

# API (Express)
PORT=8080
# Homologação: se a porta estiver em uso, use outra (ex.: 8081) e acesse http://IP_DO_SERVIDOR:8081
# Ajuste ALLOWED_ORIGIN para a mesma origem (mesmo host, porta e esquema) que o navegador usa.

# Produção ou homolog em subcaminho (ex.: https://rgrservices.com.br/casamento360).
# Na API: APP_BASE_PATH=/casamento360 (sem barra final). O cliente usa /casamento360/api.
# Desenvolvimento local com `pnpm dev:homolog`: deixe APP_BASE_PATH comentado — o Vite encaminha /casamento360/api para a API em /api.
# Em deploy atrás do Nginx (subcaminho), defina APP_BASE_PATH no processo da API (ex.: systemd).
# APP_BASE_PATH=/casamento360

# Opcional: pasta absoluta para uploads. Se vazio, usa <raiz do monorepo>/uploads.
# Em produção em /opt/app: UPLOAD_ROOT=/opt/app/uploads
# UPLOAD_ROOT=/opt/app/uploads

# Migração única (gifts → gift em disco + gifts.image_url): pnpm run db:migrate:gift-uploads

# Desenvolvimento: porta da API para o proxy do Vite (deve ser a mesma do Express — normalmente igual a PORT).
DEV_API_PORT=8080

# Frontend (Vite): `pnpm dev` usa BASE_PATH=/ . Para homolog local use `pnpm dev:homolog` (BASE_PATH=/casamento360/).
# A base da API no browser vem do BASE_URL do Vite (não é obrigatório definir VITE_API_BASE).
# Não use VITE_API_BASE=/api junto com dev:homolog — isso quebra URLs de mídia em /api/uploads.

# Opcional em desenvolvimento (obrigatório em produção)
# JWT_SECRET=uma-chave-longa-e-aleatoria

# Origem permitida pelo CORS (obrigatório em produção; em dev o padrão já é http://localhost:5173)
# ALLOWED_ORIGIN=https://rgrservices.com.br
